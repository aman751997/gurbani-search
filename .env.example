# Copy to .env.local and fill in values. Never commit .env.local.

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
# Postgres connection string — only used by ingestion/seed_supabase.py (laptop-only)
SUPABASE_DB_URL=

# Cloudflare Workers AI (BGE-M3 embeddings)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_AI_API_TOKEN=

# Caption LLM — set to "groq" (default) or "anthropic"
LLM_PROVIDER=groq
GROQ_API_KEY=
ANTHROPIC_API_KEY=

# Upstash Redis (rate limiting)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Production domain for CORS (e.g. https://gurbani.example.app)
PROD_DOMAIN=
