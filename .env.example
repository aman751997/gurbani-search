# =============================================================================
# gurbani-search environment variables
# =============================================================================
# Copy this file to `.env.local` and fill in the values. Never commit `.env.local`.
#
# SECURITY: SERVICE_KEY and AI tokens below are SERVER-ONLY. They must never be
# imported from a 'use client' module or exposed to the browser. Anything that
# should reach the client must be prefixed with NEXT_PUBLIC_ (none are, by design).
# =============================================================================

# --- Supabase ----------------------------------------------------------------
# Project URL (safe to expose to client if ever needed via NEXT_PUBLIC_ prefix)
SUPABASE_URL=
# Anon key — client-readable corpus reads only. Row-level security enforced.
SUPABASE_ANON_KEY=
# Service key — SERVER-ONLY. Used for caption_cache writes. Do NOT expose.
SUPABASE_SERVICE_KEY=

# --- Cloudflare Workers AI (embeddings via @cf/baai/bge-m3) -----------------
# SERVER-ONLY. Used for both ingestion (laptop) and query-time embedding.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_AI_API_TOKEN=

# --- Anthropic (caption generation via Claude 4.5 Haiku) --------------------
# SERVER-ONLY. Never import from a 'use client' module.
ANTHROPIC_API_KEY=

# --- Upstash Redis (rate limiting via @upstash/ratelimit) -------------------
# SERVER-ONLY. Used exclusively from middleware.ts.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Deployment --------------------------------------------------------------
# Production domain used by CORS policy in middleware.ts. Example: https://gurbani.example.app
# Leave blank in preview; middleware falls through to wildcard in non-production.
PROD_DOMAIN=
